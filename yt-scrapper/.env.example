# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration
MONGO_URI=
REDIS_URL=redis://localhost:6379

# API Keys - YouTube & Custom Search
# Get from: https://console.cloud.google.com
GOOGLE_API_KEYS=key1,key2,key3
GOOGLE_CX=your_custom_search_engine_id

# SerpAPI Keys - Google Search (more reliable)
# Get from: https://serpapi.com
SERPAPI_KEYS=your_serpapi_key_1,your_serpapi_key_2

# Proxy Configuration (comma-separated)
# Format: http://ip:port or http://user:pass@ip:port or socks5://ip:port
PROXY_LIST=http://proxy1.com:8080,http://proxy2.com:8080

# Browser Configuration
MAX_BROWSERS=5
MAX_PAGES=20
MAX_RETRIES=3
TIMEOUT=30000

# Request Rate Limiting
REQUESTS_PER_MINUTE=60

# Scraping Targets
TARGET_EMAILS=6000
CHANNELS_PER_QUERY=50
MAX_CHANNELS_PER_KEYWORD=500

# Keyword Expansion
USE_AI_EXPANSION=false
MAX_KEYWORDS=20

# Additional Settings
LOG_LEVEL=info
ENABLE_DASHBOARD=true
ENABLE_SOCKET_IO=true
